<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#FFFFFF">
    <View android:layout_width="40dp" android:layout_height="4dp" android:background="#C7C7CC"
        android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:layout_marginBottom="4dp"/>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="32dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="8dp" android:layout_marginBottom="20dp">
                <TextView android:id="@+id/sheetTitle" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Add New Habit" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="#1C1C1E"/>
                <ImageButton android:id="@+id/closeBtn" android:layout_width="36dp"
                    android:layout_height="36dp" android:background="@drawable/close_bg"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#8E8E93" android:contentDescription="Close"/>
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Habit name / description" android:textSize="13sp"
                android:textColor="#8E8E93" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/habitNameInput" android:layout_width="match_parent"
                android:layout_height="56dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textSize="15sp" android:textColor="#1C1C1E"
                android:hint="e.g. Drink 8 glasses of water"
                android:inputType="textCapSentences" android:layout_marginBottom="20dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Goal direction" android:textSize="13sp"
                android:textColor="#8E8E93" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <TextView android:id="@+id/doMoreBtn" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:text="Do more" android:gravity="center" android:textSize="14sp"
                    android:background="@drawable/toggle_on" android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/doLessBtn" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:text="Do less" android:gravity="center" android:textSize="14sp"
                    android:background="@drawable/toggle_off" android:textColor="#1C1C1E"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/factCard" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@drawable/fact_bg" android:padding="14dp"
                android:layout_marginBottom="20dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡 Did you know?" android:textSize="12sp"
                    android:textColor="#667EEA" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/factText" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="#3C3C43" android:lineSpacingExtra="3dp"/>
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Tracking period" android:textSize="13sp"
                android:textColor="#8E8E93" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/dailyBtn" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:text="Daily" android:gravity="center" android:textSize="14sp"
                    android:background="@drawable/toggle_on" android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/weeklyBtn" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:text="Weekly" android:gravity="center" android:textSize="14sp"
                    android:background="@drawable/toggle_off" android:textColor="#1C1C1E"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/monthlyBtn" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:text="Monthly" android:gravity="center" android:textSize="14sp"
                    android:background="@drawable/toggle_off" android:textColor="#1C1C1E"/>
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="How often you want to track this habit"
                android:textSize="12sp" android:textColor="#AEAEB2" android:layout_marginBottom="20dp"/>
            <TextView android:id="@+id/goalLabel" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Goal per period"
                android:textSize="13sp" android:textColor="#8E8E93" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="28dp">
                <ImageButton android:id="@+id/goalMinus" android:layout_width="56dp"
                    android:layout_height="56dp" android:background="@drawable/stepper_bg"
                    android:src="@android:drawable/ic_input_delete"
                    android:tint="#1C1C1E" android:contentDescription="Decrease"/>
                <TextView android:id="@+id/goalCountText" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="1" android:gravity="center" android:textSize="22sp"
                    android:textStyle="bold" android:textColor="#1C1C1E"
                    android:background="@drawable/input_bg" android:layout_marginHorizontal="8dp"/>
                <ImageButton android:id="@+id/goalPlus" android:layout_width="56dp"
                    android:layout_height="56dp" android:background="@drawable/stepper_bg"
                    android:src="@android:drawable/ic_input_add"
                    android:tint="#1C1C1E" android:contentDescription="Increase"/>
            </LinearLayout>
            <TextView android:id="@+id/saveBtn" android:layout_width="match_parent"
                android:layout_height="56dp" android:text="Start tracking"
                android:gravity="center" android:textSize="16sp"
                android:textStyle="bold" android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
