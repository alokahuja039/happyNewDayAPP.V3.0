<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F2F2F7">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="20dp" android:paddingEnd="16dp"
        android:paddingTop="52dp" android:paddingBottom="12dp">
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="To-Do"
            android:textSize="28sp" android:textStyle="bold"
            android:textColor="#1C1C1E" android:fontFamily="sans-serif-black"/>
        <ImageButton android:id="@+id/addTodoBtn"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="@drawable/fab_bg"
            android:src="@android:drawable/ic_input_add"
            android:tint="#FFFFFF" android:contentDescription="Add task"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/emptyTodos"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center" android:padding="40dp" android:visibility="gone">
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#x2705;" android:textSize="64sp" android:layout_marginBottom="20dp"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="All clear!" android:textSize="22sp" android:textStyle="bold"
            android:textColor="#1C1C1E" android:layout_marginBottom="8dp"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tap + to add your first task."
            android:textSize="15sp" android:textColor="#8E8E93" android:gravity="center"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTodos"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:clipToPadding="false" android:visibility="gone"/>
</LinearLayout>