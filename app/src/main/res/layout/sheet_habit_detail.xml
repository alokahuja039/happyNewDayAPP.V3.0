<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#FFFFFF">
    <View android:layout_width="40dp" android:layout_height="4dp" android:background="#C7C7CC"
        android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:layout_marginBottom="8dp"/>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="28dp">
            <TextView android:id="@+id/detailName" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="22sp"
                android:textStyle="bold" android:textColor="#1C1C1E"
                android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/detailStatus" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:textColor="#8E8E93" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/detailStreak" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="#3C3C43" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/detailLogged" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="#8E8E93" android:layout_marginBottom="20dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.habittracker.app.RadialProgressView android:id="@+id/d7d"
                        android:layout_width="72dp" android:layout_height="72dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last 7 days" android:textSize="10sp"
                        android:textColor="#8E8E93" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.habittracker.app.RadialProgressView android:id="@+id/d4w"
                        android:layout_width="72dp" android:layout_height="72dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last 4 weeks" android:textSize="10sp"
                        android:textColor="#8E8E93" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.habittracker.app.RadialProgressView android:id="@+id/d3m"
                        android:layout_width="72dp" android:layout_height="72dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last 3 months" android:textSize="10sp"
                        android:textColor="#8E8E93" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.habittracker.app.RadialProgressView android:id="@+id/d1y"
                        android:layout_width="72dp" android:layout_height="72dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Last 1 year" android:textSize="10sp"
                        android:textColor="#8E8E93" android:gravity="center" android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/fact_bg" android:padding="14dp" android:layout_marginBottom="24dp">
                <TextView android:id="@+id/detailQuote" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="#3C3C43" android:textStyle="italic" android:lineSpacingExtra="3dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btnClose" android:layout_width="52dp"
                        android:layout_height="52dp" android:background="@drawable/action_bg"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="#8E8E93" android:contentDescription="Close"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Close" android:textSize="10sp"
                        android:textColor="#8E8E93" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btnCalendar" android:layout_width="52dp"
                        android:layout_height="52dp" android:background="@drawable/action_bg"
                        android:src="@android:drawable/ic_menu_today"
                        android:tint="#667EEA" android:contentDescription="View log"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Log" android:textSize="10sp"
                        android:textColor="#8E8E93" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btnMarkDone" android:layout_width="52dp"
                        android:layout_height="52dp" android:background="@drawable/action_green"
                        android:src="@android:drawable/checkbox_on_background"
                        android:tint="#27AE60" android:contentDescription="Mark done"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Done" android:textSize="10sp"
                        android:textColor="#8E8E93" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btnDelete" android:layout_width="52dp"
                        android:layout_height="52dp" android:background="@drawable/action_red"
                        android:src="@android:drawable/ic_menu_delete"
                        android:tint="#E74C3C" android:contentDescription="Delete"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Delete" android:textSize="10sp"
                        android:textColor="#8E8E93" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btnEdit" android:layout_width="52dp"
                        android:layout_height="52dp" android:background="@drawable/action_bg"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="#667EEA" android:contentDescription="Edit"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Edit" android:textSize="10sp"
                        android:textColor="#8E8E93" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
